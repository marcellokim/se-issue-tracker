@startuml sd-27-change-priority-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 27 - Change Priority
hide footbox

actor "PL" as PL
participant ":IssueTrackingSystem" as IC
participant "targetIssue:Issue" as Issue

PL -> IC : changePriority(issueId, newPriority)

alt PL cannot change priority or newPriority is invalid
  IC --> PL : priorityChangeRejected(reason)
else valid priority change
  IC -> Issue : changePriority(newPriority, currentPL, now)
  activate Issue
  Issue -> Issue : oldPriority := currentPriority;\npriority = newPriority
  create "priorityHistory:IssueHistory" as PriorityHistory
  Issue --> PriorityHistory : new(PRIORITY_CHANGED,\noldPriority -> newPriority)
  Issue -> Issue : addHistory(priorityHistory)
  Issue --> IC : priorityChanged(newPriority)
  deactivate Issue
  IC --> PL : priorityChanged(issueId, priority=newPriority)
end

note right of Issue
Status and assignment associations remain unchanged.
end note

@enduml
