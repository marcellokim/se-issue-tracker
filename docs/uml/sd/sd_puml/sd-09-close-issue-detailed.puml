@startuml sd-09-close-issue-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 09 - Close Issue
hide footbox

actor "PL" as PL
participant ":IssueTrackingSystem" as ISC
participant "targetIssue:Issue" as Issue

PL -> ISC : changeStatus(issueId, CLOSED, comment)

alt 상태 또는 권한 조건이 맞지 않음
  ISC --> PL : statusChangeRejected(reason)
else 상태 변경 사유가 비어 있음
  ISC --> PL : statusChangeRejected(commentRequired)
else RESOLVED -> CLOSED 전이가 가능함
  ISC -> Issue : close(currentPL, comment, now)
  activate Issue
  create "closeComment:Comment" as Comment
  Issue --> Comment : new(content=comment,\nwriter=currentPL,\npurpose=STATUS_CHANGE)
  create "commentHistory:IssueHistory" as CommentHistory
  Issue --> CommentHistory : new(COMMENTED, message=comment)
  create "statusHistory:IssueHistory" as StatusHistory
  Issue --> StatusHistory : new(STATUS_CHANGED, RESOLVED -> CLOSED)
  Issue -> Issue : clear assignee/verifier;\npreserve fixer/resolver;\nstatus=CLOSED
  Issue --> ISC : updated(status=CLOSED)
  deactivate Issue
  ISC --> PL : updatedIssue(issueId, status=CLOSED)
end

@enduml
