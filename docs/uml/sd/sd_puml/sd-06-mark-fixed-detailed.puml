@startuml sd-06-mark-fixed-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 06 - Mark Issue as Fixed
hide footbox

actor "DEV" as Dev
participant ":IssueTrackingSystem" as ISC
participant "targetIssue:Issue" as Issue

Dev -> ISC : changeStatus(issueId, FIXED, comment)

alt DEV cannot mark this issue fixed or comment is blank
  ISC --> Dev : statusChangeRejected(reason)
else valid ASSIGNED -> FIXED transition
  ISC -> Issue : markFixed(currentDev, comment, now)
  activate Issue
  create "fixComment:Comment" as Comment
  Issue --> Comment : new(content=comment, writer=currentDev)
  create "commentHistory:IssueHistory" as CommentHistory
  Issue --> CommentHistory : new(COMMENTED, message=comment)
  create "statusHistory:IssueHistory" as StatusHistory
  Issue --> StatusHistory : new(STATUS_CHANGED, ASSIGNED -> FIXED)
  Issue -> Issue : fixer=currentDev;\nstatus=FIXED;\nadd comment/history
  Issue --> ISC : updated(status=FIXED)
  deactivate Issue
  ISC --> Dev : updatedIssue(issueId, status=FIXED)
end

@enduml
