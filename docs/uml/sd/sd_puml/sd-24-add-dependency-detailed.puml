@startuml sd-24-add-dependency-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 24 - Add Dependency
hide footbox

actor "PL" as PL
participant ":IssueTrackingSystem" as IC
participant "blockingIssue:Issue" as BlockingIssue
participant "blockedIssue:Issue" as BlockedIssue

PL -> IC : addDependency(blockingIssueId, blockedIssueId)

alt PL cannot manage dependency or issues are invalid
  IC --> PL : dependencyRejected(reason)
else dependency can be considered
  IC -> BlockedIssue : checkDependencyCandidate(blockingIssue)
  BlockedIssue -> BlockedIssue : rejectSelfDuplicateOrCycle()
  BlockedIssue --> IC : dependencyAllowed

  IC -> BlockedIssue : addDependency(dependencyId,\nblockingIssue, currentPL, now)
  activate BlockedIssue
  create "newDependency:IssueDependency" as Dependency
  BlockedIssue --> Dependency : new(blockingIssue, blockedIssue,\ndiscoveredDate=now)
  create "dependencyHistory:IssueHistory" as History
  BlockedIssue --> History : new(DEPENDENCY_CHANGED,\nnewValue=dependencyId)
  BlockedIssue -> BlockedIssue : addDependencyHistory(history)
  BlockedIssue --> IC : dependencyAdded(dependencyId)
  deactivate BlockedIssue

  IC --> PL : dependencyAdded(dependencyId)
end

note over BlockingIssue, BlockedIssue
blockingIssue must be resolved or closed before blockedIssue can be resolved.
Add dependency itself does not reject resolved or closed blockedIssue.
The dependency itself is not an IssueStatus.
end note

@enduml
