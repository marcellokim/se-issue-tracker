@startuml sd-01-register-issue-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 01 - Register Issue
hide footbox

actor "Auth User" as User
participant ":IssueTrackingSystem" as IC
participant "targetProject:Project" as Project
participant "reporter:User" as Reporter
participant "newIssue:Issue" as Issue

User -> IC : registerIssue(projectId, title, description, priority)

alt login, permission, or project membership is invalid
  IC --> User : registrationRejected(reason)
else title/description invalid or duplicate title exists
  IC --> User : registrationRejected(reason)
else registration is accepted
  note right of IC
  Current code uses service/repository/clock internally.
  At SD level they are summarized as checks before
  domain objects realize the postconditions.
  end note

  IC -> Project : confirmSelectedProject()
  Project --> IC : projectConfirmed
  IC -> Reporter : confirmReporter()
  Reporter --> IC : reporterConfirmed

  create Issue
  IC --> Issue : create(projectId, title, description,\npriority or MAJOR, reporter, now)
  activate Issue

  create "createdHistory:IssueHistory" as CreatedHistory
  Issue --> CreatedHistory : new(CREATED,\nprevious=null, new=NEW,\nchangedBy=reporter)
  Issue -> Issue : addHistory(createdHistory)

  Issue --> IC : issueCreated(status=NEW)
  deactivate Issue
  IC --> User : issueRegistered(issueId, status=NEW)
end

opt user adds an initial comment
  User -> IC : addComment(issueId, content)
  alt content is blank
    IC --> User : commentRejected(reason)
  else comment is accepted
    IC -> Issue : addComment(content, reporter, now)
    activate Issue
    create "initialComment:Comment" as Comment
    Issue --> Comment : new(content, writer=reporter, createdAt=now)
    create "commentHistory:IssueHistory" as CommentHistory
    Issue --> CommentHistory : new(COMMENTED, message="comment added")
    Issue -> Issue : addComment(initialComment)
    Issue -> Issue : addHistory(commentHistory)
    Issue --> IC : commentAdded(commentId)
    deactivate Issue
    IC --> User : commentAdded(commentId)
  end
end

@enduml
