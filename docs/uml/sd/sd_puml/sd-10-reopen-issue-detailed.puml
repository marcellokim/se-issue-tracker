@startuml sd-10-reopen-issue-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 10 - Reopen Issue
hide footbox

actor "PL" as PL
participant ":IssueTrackingSystem" as ISC
participant "targetIssue:Issue" as Issue
participant "projectMembers:User[*]" as Members

PL -> ISC : changeStatus(issueId, REOPENED, comment)

alt PL cannot reopen this issue or comment is blank
  ISC --> PL : statusChangeRejected(reason)
else valid reopen transition
  ISC -> Issue : reopen(currentPL, comment, now)
  activate Issue
  create "reopenComment:Comment" as Comment
  Issue --> Comment : new(content=comment, writer=currentPL)
  create "commentHistory:IssueHistory" as CommentHistory
  Issue --> CommentHistory : new(COMMENTED, message=comment)
  create "statusHistory:IssueHistory" as StatusHistory
  Issue --> StatusHistory : new(STATUS_CHANGED, RESOLVED/CLOSED -> REOPENED)
  Issue -> Issue : clear assignee/verifier;\npreserve fixer/resolver;\nstatus=REOPENED
  Issue --> ISC : updated(status=REOPENED)
  deactivate Issue
  ISC --> PL : updatedIssue(issueId, status=REOPENED)
end

opt PL assigns work again
  PL -> ISC : startAssignment(issueId)
  ISC -> Issue : readAssignmentState()
  Issue --> ISC : status=REOPENED,\nfixer/resolver preserved
  ISC -> Members : selectActiveDevAndTester()
  Members --> ISC : assignee/verifier candidates
  ISC --> PL : assignmentOptions(devs, testers)
  PL -> ISC : assignIssue(issueId, assigneeId, verifierId)
  ISC -> Issue : assignReopened(assignee, verifier, currentPL, now)
  activate Issue
  Issue -> Issue : set assignee/verifier;\npreserve fixer/resolver;\nstatus=ASSIGNED
  create "assignmentHistory:IssueHistory" as AssignmentHistory
  Issue --> AssignmentHistory : new(ASSIGNMENT_CHANGED)
  create "assignedStatusHistory:IssueHistory" as AssignedStatusHistory
  Issue --> AssignedStatusHistory : new(STATUS_CHANGED, REOPENED -> ASSIGNED)
  Issue -> Issue : addHistory(assignmentHistory)
  Issue -> Issue : addHistory(assignedStatusHistory)
  Issue --> ISC : assigned(status=ASSIGNED)
  deactivate Issue
  ISC --> PL : issueAssigned(issueId, status=ASSIGNED)
end

@enduml
