@startuml sd-26-restore-deleted-issue-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 26 - Restore Deleted Issue
hide footbox

actor "PL" as PL
participant ":IssueTrackingSystem" as DIC
participant "targetIssue:Issue" as Issue
participant "deleteHistory:IssueHistory" as DeleteHistory

PL -> DIC : viewDeletedIssues(projectId)
DIC --> PL : deletedIssueList

PL -> DIC : restoreIssue(issueId, comment)

alt status or permission is invalid
  DIC --> PL : restoreRejected(reason)
else comment is blank
  DIC --> PL : restoreRejected(commentRequired)
else valid restore target
  DIC -> Issue : findDeleteTransition()
  Issue -> DeleteHistory : previousValue()
  DeleteHistory --> Issue : NEW or CLOSED
  DIC -> Issue : restoreTo(previousStatus,\ncurrentPL, comment, now)
  activate Issue
  create "restoreHistory:IssueHistory" as RestoreHistory
  Issue --> RestoreHistory : new(STATUS_CHANGED,\nDELETED -> previousStatus)
  Issue -> Issue : status=previousStatus;\nkeep reporter/fixer/resolver;\nkeep assignee/verifier empty
  Issue --> DIC : restored(status=previousStatus)
  deactivate Issue

  DIC --> PL : issueRestored(issueId, status)
end

note right of Issue
Dependencies removed during soft delete are not restored automatically.
end note

@enduml
