@startuml sd-07-resolve-fixed-issue-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 07 - Resolve Fixed Issue
hide footbox

actor "Tester" as Tester
participant ":IssueTrackingSystem" as ISC
participant "targetIssue:Issue" as Issue
participant "blockingIssue:Issue" as BlockingIssue

Tester -> ISC : changeStatus(issueId, RESOLVED, comment)

alt Tester cannot resolve this issue or comment is blank
  ISC --> Tester : statusChangeRejected(reason)
else basic transition rule is satisfied
  loop each issue blocking targetIssue
    Issue -> BlockingIssue : isResolvedOrClosed()
    BlockingIssue --> Issue : true or false
  end

  alt unresolved blocking issue exists
    ISC --> Tester : statusChangeRejected(blockingIssueId)
  else all blocking issues are resolved or closed
    ISC -> Issue : resolve(currentTester, comment, now)
    activate Issue
    create "resolveComment:Comment" as Comment
    Issue --> Comment : new(content=comment, writer=currentTester)
    create "commentHistory:IssueHistory" as CommentHistory
    Issue --> CommentHistory : new(COMMENTED, message=comment)
    create "statusHistory:IssueHistory" as StatusHistory
    Issue --> StatusHistory : new(STATUS_CHANGED, FIXED -> RESOLVED)
    Issue -> Issue : resolver=currentTester;\nclear assignee/verifier;\nstatus=RESOLVED
    note right of Issue
    Dependency rows are kept.
    They are not auto-removed by resolve.
    end note
    Issue --> ISC : updated(status=RESOLVED)
    deactivate Issue
    ISC --> Tester : updatedIssue(issueId, status=RESOLVED)
  end
end

@enduml
