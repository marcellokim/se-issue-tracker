@startuml ucd-issue-tracking-system
!include ../_shared/its-uml-style.puml

left to right direction
hide stereotype
skinparam nodesep 25
skinparam ranksep 30
skinparam ArrowThickness 1.6
skinparam ArrowFontSize 18
skinparam ArrowFontColor #000000
skinparam usecase {
  FontSize 15
  BorderColor #000000
  BackgroundColor #FFFFFF
  FontColor #000000
  BorderColor<<shared>> #0077ff
  BorderColor<<pl>> #f80606
  BorderColor<<admin>> #9806f3
  BorderColor<<include>> #b65c3b
  BackgroundColor<<include>> #FFF8E1
}
skinparam actor {
  FontSize 15
  BorderColor #000000
  BackgroundColor #FFFFFF
  FontColor #000000
}

title Issue Tracking System - Use Case Diagram

actor Admin as Admin
actor "Auth User\n<<abstract>>" as AuthUser
actor Tester as Tester
actor Dev as Dev
actor PL as PL

Tester --|> AuthUser 
Dev --|> AuthUser
PL --|> AuthUser

rectangle "Issue Tracking System" as System {
  usecase "UC11\nLog In" as UC11 <<shared>>
  usecase "UC1\nRegister Issue" as UC1 <<shared>>
  usecase "UC3\nSearch Issues" as UC3 <<shared>>
  usecase "UC4\nView Issue Detail" as UC4 <<shared>>
  usecase "UC2\nAdd Comment" as UC2 <<shared>>
  usecase "UC15\nEdit Issue\n(reporter only,\nNEW or REOPENED)" as UC15 <<shared>>
  usecase "UC6\nChange Issue State" as UC6 <<shared>>
  usecase "UC10\nStatistics" as UC10 <<shared>>

  usecase "UC5\nAssign / Update\nIssue\nAssignment" as UC5 <<pl>>
  usecase "UC8\nRecommend\nAssignment\nCandidates" as UC8 <<include>>
  usecase "UC16\nChange Priority" as UC16 <<pl>>
  usecase "UC7\nManage Dependency" as UC7 <<pl>>
  usecase "UC9\nManage Deleted Issue" as UC9 <<pl>>

  usecase "UC12\nManage Accounts" as UC12 <<admin>>
  usecase "UC13\nManage Projects" as UC13 <<admin>>
  usecase "UC14\nVerify Permission" as UC14 <<include>>
}

Admin -[#B0BEC5]- UC11
Admin -[#B0BEC5]- UC12
Admin -[#B0BEC5]- UC13

AuthUser -[#B0BEC5]- UC11
AuthUser -[#B0BEC5]- UC1
AuthUser -[#B0BEC5]- UC3
AuthUser -[#B0BEC5]- UC4
AuthUser -[#B0BEC5]- UC6
AuthUser -[#B0BEC5]- UC10

PL -[#B0BEC5]- UC5
PL -[#B0BEC5]- UC7
PL -[#B0BEC5]- UC9
PL -[#B0BEC5]- UC16

UC1 .[#8D6E63].> UC14 : <<include>>
UC5 .[#8D6E63].> UC8 : <<include>>
UC5 .[#8D6E63].> UC14 : <<include>>
UC6 .[#8D6E63].> UC2 : <<include>>
UC6 .[#8D6E63].> UC14 : <<include>>
UC7 .[#8D6E63].> UC14 : <<include>>
UC9 .[#8D6E63].> UC14 : <<include>>
UC9 .[#8D6E63].> UC2 : <<include>>
UC10 .[#8D6E63].> UC14 : <<include>>
UC12 .[#8D6E63].> UC14 : <<include>>
UC13 .[#8D6E63].> UC14 : <<include>>
UC16 .[#8D6E63].> UC14 : <<include>>

UC2 .[#269797].> UC1 : <<extend>>
UC2 .[#269797].> UC4 : <<extend>>
UC2 .[#269797].> UC5 : <<extend>>
UC15 .[#269797].> UC4 : <<extend>>

@enduml
