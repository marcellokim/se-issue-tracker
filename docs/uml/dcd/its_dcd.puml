@startuml its_dcd
!include ../_shared/its-uml-style.puml

title Issue Tracking System - DCD (Domain Design Classes)

left to right direction
hide circle
skinparam monochrome true
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 70
skinparam ranksep 58
scale 0.9

legend left
  == DCD focus ==
  Larman-style Design Class Diagram.
  It extends the domain model with design-level
  attributes, operations, navigability, role names,
  and multiplicities.

  This view intentionally omits persistence helpers,
  repository/JDBC classes, service orchestration,
  UI classes, result DTOs, and bootstrap wiring.
endlegend

class User <<entity>> {
  -loginId : String
  -name : String
  -passwordHash : String
  -role : Role
  -active : boolean
  --
  +hasRole(role : Role) : boolean
  +rename(name : String, changedAt : LocalDateTime) : void
  +changeRole(role : Role, changedAt : LocalDateTime) : void
  +activate(changedAt : LocalDateTime) : void
  +deactivate(changedAt : LocalDateTime) : void
}

class Project <<entity>> {
  -id : long
  -name : String
  -description : String
  -managedByLoginId : String
  --
  +rename(name : String, updatedAt : LocalDateTime) : void
  +changeDescription(description : String, updatedAt : LocalDateTime) : void
}

class ProjectMember <<association class>> {
  -projectId : long
  -userId : String
  -joinedAt : LocalDateTime
}

class Issue <<aggregate root>> {
  -id : long
  -projectId : long
  -issueId : String
  -title : String
  -description : String
  -priority : Priority
  -status : IssueStatus
  -reportedDate : LocalDateTime
  -updatedAt : LocalDateTime
  --
  +updateTitleAndDescription(title : String, description : String, actor : User, changedAt : LocalDateTime) : void
  +changePriority(priority : Priority, actor : User, changedAt : LocalDateTime) : void
  +assignFromNew(assignee : User, verifier : User, actor : User, changedAt : LocalDateTime) : void
  +assignReopened(assignee : User, verifier : User, actor : User, changedAt : LocalDateTime) : void
  +reassignAssignee(assignee : User, actor : User, changedAt : LocalDateTime) : void
  +changeVerifier(verifier : User, actor : User, changedAt : LocalDateTime) : void
  +markFixed(fixer : User, comment : String, changedAt : LocalDateTime) : void
  +rejectFix(tester : User, comment : String, changedAt : LocalDateTime) : void
  +resolve(resolver : User, comment : String, changedAt : LocalDateTime) : void
  +close(actor : User, comment : String, changedAt : LocalDateTime) : void
  +reopen(actor : User, comment : String, changedAt : LocalDateTime) : void
  +addComment(commentId : String, content : String, writer : User, purpose : CommentPurpose, createdAt : LocalDateTime) : Comment
  +recordCommentDeletion(comment : Comment, actor : User, changedAt : LocalDateTime) : void
  +addDependency(dependencyId : String, blockingIssue : Issue, actor : User, discoveredAt : LocalDateTime) : IssueDependency
  +removeDependency(dependency : IssueDependency, actor : User, changedAt : LocalDateTime) : void
}

class Comment <<entity>> {
  -id : long
  -commentId : String
  -content : String
  -purpose : CommentPurpose
  -createdDate : LocalDateTime
  -updatedDate : LocalDateTime
  --
  +changeContent(content : String, changedAt : LocalDateTime) : void
}

class IssueHistory <<entity>> {
  -id : long
  -historyId : String
  -actionType : ActionType
  -previousValue : String
  -newValue : String
  -message : String
  -changedDate : LocalDateTime
}

class IssueDependency <<association class>> {
  -id : long
  -dependencyId : String
  -blockingIssueId : long
  -blockedIssueId : long
  -discoveredDate : LocalDateTime
  --
  +dependencyIdFor(blockingIssueId : long, blockedIssueId : long) : String
}

enum Role {
  ADMIN
  PL
  DEV
  TESTER
}

enum IssueStatus {
  NEW
  ASSIGNED
  FIXED
  RESOLVED
  CLOSED
  REOPENED
  DELETED
}

enum Priority {
  BLOCKER
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum CommentPurpose {
  GENERAL
  STATUS_CHANGE
}

enum ActionType {
  CREATED
  TITLE_DESCRIPTION_UPDATED
  PRIORITY_CHANGED
  STATUS_CHANGED
  ASSIGNMENT_CHANGED
  DEPENDENCY_CHANGED
  COMMENTED
}

' Main domain relationships.
Project "1" <-- "0..*" ProjectMember : project
ProjectMember "*" --> "1" User : participant
Project "*" ..> "1" User : managed by

Issue "*" ..> "1" Project : belongs to
Issue "*" --> "1" User : reporter
Issue "*" --> "0..1" User : assignee
Issue "*" --> "0..1" User : verifier
Issue "*" --> "0..1" User : fixer
Issue "*" --> "0..1" User : resolver

Issue "1" *-- "0..*" Comment : comments {ordered}
Issue "1" *-- "0..*" IssueHistory : histories {ordered}
Comment "*" --> "1" User : writer
IssueHistory "*" --> "1" User : changed by

Issue "1" --> "0..*" IssueDependency : dependencies blocking this issue
Issue "1" --> "0..*" IssueDependency : dependencies blocked by this issue
IssueDependency "*" --> "1" Issue : blocking issue
IssueDependency "*" --> "1" Issue : blocked issue

User --> Role
Issue --> IssueStatus
Issue --> Priority
Comment --> CommentPurpose
IssueHistory --> ActionType

note right of Issue
Issue is the main Information Expert.
It owns assignment changes, status transitions,
priority changes, comment history, and dependency history.
end note

note bottom of Project
Project does not own a List<Issue>.
Issues are connected to a project by projectId,
and project issue queries are coordinated outside
the domain object.
end note

note bottom of ProjectMember
Association class for Project-User participation.
end note

note bottom of IssueDependency
Association class for Issue-to-Issue dependency.
A blocking issue must be resolved or closed before
the blocked issue can be resolved.
Resolved dependencies are kept until explicit removal
or issue soft delete.
end note

@enduml
