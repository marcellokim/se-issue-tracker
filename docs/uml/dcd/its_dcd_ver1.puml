@startuml its_dcd_ver1
!include ../_shared/its-uml-style.puml

title Issue Tracking System - DCD ver1: Current Layered Implementation

left to right direction
hide circle
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam nodesep 35
skinparam ranksep 45
scale 0.52

legend left
  == Purpose ==
  ver1 shows the current implementation layers and dependency direction.
  UI files are intentionally not modeled as completed JavaFX/Swing views.
  Presentation/CLI boundaries must call controllers, not services/repositories.

  == Dependency Rule ==
  Controller -> Service -> Repository ports / Domain / Service ports
  Persistence implements repository ports.
  Technical adapters implement service ports.
  ApplicationBootstrap is the composition root.
endlegend

package "Presentation / Entry Points" #E3F2FD {
  class Main <<boundary>> {
    +main(args)
  }

  class CommandLineEntryPoint <<boundary>> {
    +main(args)
  }

  class ConsoleCliOutput <<boundary>>
}

package "Composition Root / Runtime Config" #E8EAF6 {
  class ApplicationBootstrap <<composition-root>> {
    -context: RepositoryContext
    -passwordHashing: PasswordHashing
    +startUiContext(): ApplicationContext
    +loginCheckService(): LoginCheckService
    +repositoryDemoSummaryService(): RepositoryDemoSummaryService
    +databaseConnectionSummary(): DatabaseConnectionSummary
  }

  class ApplicationContext <<runtime-context>> {
    +authenticationController(): AuthenticationController
    +accountController(): AccountController
    +dashboardController(): DashboardController
    +projectController(): ProjectController
    +issueController(): IssueController
    +assignmentController(): AssignmentController
    +issueStateController(): IssueStateController
    +deletedIssueController(): DeletedIssueController
    +statisticsController(): StatisticsController
  }
}

package "Controller Layer\n(system operation receivers)" #FFF8E1 {
  class AuthenticationController <<control>> {
    +login(loginId, password): AuthenticationResult
    +logout(): void
  }

  class DashboardController <<control>> {
    +viewProjects(): List<DashboardProjectSummary>
    +viewUsers(): List<UserResult>
    +viewRelatedIssues(): List<IssueSummary>
  }

  class AccountController <<control>> {
    +createAccount(loginId, name, password, role): UserResult
    +renameAccount(loginId, name): UserResult
    +changeAccountRole(loginId, role): UserResult
    +activateAccount(loginId): UserResult
    +deactivateAccount(loginId): UserResult
  }

  class ProjectController <<control>> {
    +viewProjectNonAdminDetail(projectId): ProjectResult
    +viewProjectAdminDetail(projectId): ProjectAdminDetail
    +viewProjectParticipants(projectId): List<ProjectMemberResult>
    +createProject(name, description): ProjectResult
    +renameProject(projectId, name): ProjectResult
    +changeProjectDescription(projectId, description): ProjectResult
    +deleteProject(projectId): void
    +addProjectParticipant(projectId, loginId): void
    +removeProjectParticipant(projectId, loginId): void
  }

  class IssueController <<control>> {
    +registerIssue(projectId, title, description, priority): IssueResult
    +viewIssueDetail(issueId): IssueDetailResult
    +searchIssues(projectId, keyword, status, priority, reporterId, assigneeId, verifierId, reportedFrom, reportedTo): List<IssueSummary>
    +viewRelatedProjectIssues(projectId): List<IssueSummary>
    +updateIssue(issueId, title, description): IssueResult
    +changePriority(issueId, priority): IssueResult
    +addComment(issueId, content): CommentResult
    +viewComments(issueId): List<CommentResult>
    +updateComment(issueId, commentId, content): CommentResult
    +deleteComment(issueId, commentId): void
    +addDependency(blockingIssueId, blockedIssueId): DependencyResult
    +viewProjectDependencies(projectId): List<DependencyResult>
    +removeDependency(blockingIssueId, blockedIssueId): void
  }

  class AssignmentController <<control>> {
    +startAssignment(issueId): AssignmentOptionsResult
    +assignIssue(issueId, assigneeId, verifierId): AssignmentResult
    +reassignIssue(issueId, assigneeId): AssignmentResult
    +changeVerifier(issueId, verifierId): AssignmentResult
  }

  class IssueStateController <<control>> {
    +changeStatus(issueId, targetStatus, comment): IssueStateResult
  }

  class DeletedIssueController <<control>> {
    +viewDeletedIssues(projectId): List<IssueSummary>
    +deleteIssue(issueId, comment): IssueSummary
    +restoreIssue(issueId, comment): IssueSummary
    +purgeOverflow(projectId): int
    +purgeDeletedIssue(issueId): void
  }

  class StatisticsController <<control>> {
    +viewStatistics(projectId): StatisticsReportResult
    +viewStatistics(projectId, dailyFrom, dailyTo, monthlyFrom, monthlyTo): StatisticsReportResult
  }
}

package "Service Layer\n(application services, policies, ports, DTO/results)" #FFF3E0 {
  class AuthenticationService <<service>> {
    +login(loginId, password): AuthenticationResult
    +logout(): void
    +currentUser(): Optional<User>
