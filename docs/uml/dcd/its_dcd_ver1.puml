package "Repository Ports" #F8FAFC {
  interface UserRepository <<repository-port>> {
    +findByLoginId(loginId): Optional<User>
    +findAll(): List<User>
    +findByRole(projectId, role): List<User>
    +findActiveByRole(projectId, role): List<User>
    +save(user): User
  }

  interface ProjectRepository <<repository-port>> {
    +findById(projectId): Optional<Project>
    +findByName(name): Optional<Project>
    +findAll(): List<Project>
    +findParticipants(projectId): List<ProjectMember>
    +existsByParticipant(loginId): boolean
    +save(project): Project
    +deleteById(projectId): void
    +addParticipant(projectId, loginId): void
    +removeParticipant(projectId, loginId): void
  }

  interface IssueRepository <<repository-port>> {
    +findById(issueId): Optional<Issue>
    +findByProject(projectId): List<Issue>
    +findDeletedByProject(projectId): List<Issue>
    +findByCriteria(criteria): List<Issue>
    +existsByProjectIdAndTitle(projectId, title): boolean
    +existsByProjectIdAndTitleExcludingIssueId(projectId, title, issueId): boolean
    +existsByResponsibleUser(loginId): boolean
    +existsActiveAssignmentByProjectAndUser(projectId, loginId): boolean
    +save(issue): Issue
    +softDelete(issueId, actorId, comment, now): Issue
    +restore(issueId, actorId, comment, now): Issue
    +purgeDeletedBeyondLimit(projectId, max): int
    +purgeDeletedById(issueId): int
  }

  interface CommentRepository <<repository-port>> {
    +save(comment): Comment
    +findByIssueId(issueId): List<Comment>
    +update(comment): Comment
    +deleteById(commentId): void
  }

  interface IssueHistoryRepository <<repository-port>> {
    +save(history): IssueHistory
    +findByIssueId(issueId): List<IssueHistory>
  }

  interface IssueDependencyRepository <<repository-port>> {
    +saveAndRecordIssueChange(dependency, blockedIssue): IssueDependency
    +findByProjectId(projectId): List<IssueDependency>
    +findByBlockedIssueId(issueId): List<IssueDependency>
    +findByBlockingIssueId(issueId): List<IssueDependency>
    +deleteAndRecordIssueChange(dependency, blockedIssue): void
  }

  interface StatisticsRepository <<repository-port>>
  interface AssignmentRecommendationRepository <<repository-port>>
}

package "Persistence Adapters" #E0F2F1 {
  class JdbcRepositoryFactory <<factory>> {
    -connectionProvider: DatabaseConnectionProvider
    -passwordHashing: PasswordHashing
    +users(): UserRepository
    +projects(): ProjectRepository
    +issues(): IssueRepository
    +comments(): CommentRepository
    +issueHistory(): IssueHistoryRepository
    +issueDependencies(): IssueDependencyRepository
    +statistics(): StatisticsRepository
    +assignmentRecommendations(): AssignmentRecommendationRepository
  }

  class JdbcUserRepository <<adapter>>
  class JdbcProjectRepository <<adapter>>
  class JdbcIssueRepository <<adapter>>
  class JdbcCommentRepository <<adapter>>
  class JdbcIssueHistoryRepository <<adapter>>
  class JdbcIssueDependencyRepository <<adapter>>
  class JdbcStatisticsRepository <<adapter>>
  class JdbcAssignmentRecommendationRepository <<adapter>>
}

package "Technical Adapters" #F3E5F5 {
  class SystemClock <<adapter>>
  class SessionStore <<adapter>>
  class CommentIdGenerator <<adapter>>
  class PasswordHasher <<adapter>>
  class DriverManagerConnectionProvider <<adapter>>
  interface DatabaseConnectionProvider <<port>>
}

package "Domain Layer" #F1F8E9 {
  class User <<entity>> {
    -loginId: String
    -name: String
    -passwordHash: String
    -role: Role
    -active: boolean
    +rename(name, changedAt): void
    +changeRole(role, changedAt): void
    +activate(changedAt): void
    +deactivate(changedAt): void
  }

  class Project <<entity>> {
    -id: long
    -name: String
    -description: String
    -managedByLoginId: String
    +rename(newName, updatedAt): void
    +changeDescription(newDescription, updatedAt): void
  }

  class ProjectMember <<entity>>

  class Issue <<aggregate-root>> {
    -id: long
    -projectId: long
    -issueId: String
    -title: String
    -description: String
    -status: IssueStatus
    -priority: Priority
    +create(state): Issue
    +fromPersistence(state): Issue
    +assignFromNew(assignee, verifier, changedBy, changedDate): void
    +assignReopened(assignee, verifier, changedBy, changedDate): void
    +reassignAssignee(assignee, changedBy, changedDate): void
    +changeVerifier(verifier, changedBy, changedDate): void
    +markFixed(fixer, comment, changedDate): void
    +resolve(resolver, comment, changedDate): void
    +rejectFix(tester, comment, changedDate): void
    +close(changedBy, comment, changedDate): void
    +reopen(changedBy, comment, changedDate): void
    +changePriority(priority, changedBy, changedDate): void
    +updateTitleAndDescription(title, description, changedBy, changedDate): void
    +addComment(commentId, content, writer, createdDate, purpose): Comment
    +recordCommentDeletion(comment, changedBy, changedDate): void
    +addDependency(dependencyId, blockingIssue, changedBy, changedDate): IssueDependency
    +removeDependency(dependency, changedBy, changedDate): void
  }

  class Comment <<entity>> {
    -id: long
    -commentId: String
    -content: String
    -purpose: CommentPurpose
    +changeContent(newContent, changedAt): void
  }

  class IssueHistory <<entity>> {
    -actionType: ActionType
    -previousValue: String
    -newValue: String
    -message: String
  }

  class IssueDependency <<entity>> {
    -dependencyId: String
    -blockingIssueId: long
    -blockedIssueId: long
    +dependencyIdFor(blockingIssueId, blockedIssueId): String
  }

  class IssueSearchCriteria <<value-object>>
  class AssignmentCandidate <<value-object>>
  class AssignmentOptions <<value-object>>
  class StatisticsReport <<value-object>>
  class ValidationResult <<value-object>>

  enum Role {
    ADMIN
    PL
    DEV
    TESTER
  }

  enum IssueStatus {
    NEW
    ASSIGNED
    FIXED
    RESOLVED
    CLOSED
    REOPENED
    DELETED
  }

  enum Priority {
    BLOCKER
    CRITICAL
    MAJOR
    MINOR
    TRIVIAL
  }

  enum CommentPurpose {
    GENERAL
    STATUS_CHANGE
  }

  enum ActionType {
    CREATED
    TITLE_DESCRIPTION_UPDATED
    PRIORITY_CHANGED
    STATUS_CHANGED
    ASSIGNMENT_CHANGED
    DEPENDENCY_CHANGED
    COMMENTED
  }
}

