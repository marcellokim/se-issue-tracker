@startuml its_dcd_ver1
!include ../_shared/its-uml-style.puml

title Issue Tracking System - Design Class Diagram

left to right direction
hide circle
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam nodesep 35
skinparam ranksep 45
scale 0.48

legend left
  == Type Notation ==
  class: concrete class unless marked abstract
  interface: contract type, implemented elsewhere
  enum: enumeration value type
  abstract class: <<abstract>> / italic name
  note: no abstract class is currently required
  == Visibility Notation ==
  + public operation
  - private attribute
  # protected member
  / derived attribute
  note: no protected or derived members are currently required
endlegend

package "Presentation Layer\n(concrete boundary)" #E3F2FD {
  class JavaFxIssueView <<boundary>> {
    +logIn(loginId, password)
    +registerIssue(title, description, priority)
    +addComment(issueId, content)
    +searchIssues(filters)
    +viewIssueDetail(issueId)
    +assignIssue(issueId, assigneeId, verifierId)
    +changeIssueState(issueId, targetStatus, comment)
    +deleteIssue(issueId)
    +restoreIssue(issueId)
    +changePriority(issueId, newPriority)
    +addDependency(blockingIssueId, blockedIssueId)
    +viewStatistics(period, filters)
  }

  class SwingAdminView <<boundary>> {
    +logIn(loginId, password)
    +createAccount(loginId, name, password, role)
    +updateAccount(loginId, name, role)
    +deactivateAccount(loginId)
    +createProject(name, description)
    +deleteProject(projectId)
    +addProjectParticipant(projectId, loginId)
    +removeProjectParticipant(projectId, loginId)
    +viewStatistics(period, filters)
  }

  note bottom of JavaFxIssueView
  JavaFX boundary는 일반 사용자 이슈 흐름
  UC1-UC10의 핵심 issue workflow를 대표한다.
  end note

  note bottom of SwingAdminView
  Swing boundary는 Admin 중심의
  account/project 관리 UI를 대표한다.
  end note
}

package "Application Layer\n(concrete controllers)" #FFF8E1 {
  class IssueController <<control>> {
    +registerIssue(title, description, priority): IssueDto
    +addComment(issueId, content): CommentDto
    +searchIssues(filters): List<IssueDto>
    +viewIssueDetail(issueId): IssueDto
    +editIssue(issueId, title, description): IssueDto
    +changePriority(issueId, newPriority): IssueDto
    +addDependency(blockingIssueId, blockedIssueId): DependencyDto
    +removeDependency(dependencyId): void
  }

  class AssignmentController <<control>> {
    +startAssignment(issueId): AssignmentOptions
    +assignIssue(issueId, assigneeId, verifierId): IssueDto
    +reassignIssue(issueId, assigneeId): IssueDto
    +changeVerifier(issueId, verifierId): IssueDto
  }

  class IssueStateController <<control>> {
    +changeStatus(issueId, targetStatus, comment): IssueDto
  }

  class DeletedIssueController <<control>> {
    +viewDeletedIssues(projectId): List<IssueDto>
    +deleteIssue(issueId): IssueDto
    +restoreIssue(issueId): IssueDto
    -enforceDeletedLimit(max): void
  }

  class AccountController <<control>> {
    +logIn(loginId, password): void
    +createAccount(loginId, name, password, role): UserDto
    +updateAccount(loginId, name, role): UserDto
    +deactivateAccount(loginId): UserDto
  }

  class ProjectController <<control>> {
    +viewProjects(): List<ProjectDto>
    +viewProject(projectId): ProjectDto
    +viewProjectParticipants(projectId): List<ProjectMemberDto>
    +viewProjectDetail(projectId): ProjectDetail
    +createProject(name, description): ProjectDto
    +deleteProject(projectId): void
    +addProjectParticipant(projectId, loginId): ProjectDto
    +removeProjectParticipant(projectId, loginId): ProjectDto
  }

  class StatisticsController <<control>> {
    +viewStatistics(period, filters): StatisticsDto
  }
}

package "Application Services / Policies\n(concrete services and policies)" #FFF3E0 {
  class AuthenticationService <<service>> {
    +currentUser(): User
    +logIn(loginId, password): User
  }

  class PermissionPolicy <<policy>> {
    +verifyPermission(user, operation, resource): boolean
    +assertCanRegisterIssue(user, project): void
    +assertCanAssignIssue(user, issue): void
    +assertCanChangeStatus(user, issue, targetStatus): void
    +assertCanManageDeletedIssue(user, issue): void
    +assertCanManageDependency(user, issue): void
    +assertCanChangePriority(user, issue): void
    +assertCanManageAccount(user): void
    +assertCanManageProject(user): void
    +assertCanViewStatistics(user, filters): void
  }

  class IssueService <<service>> {
    +registerIssue(projectId, title, description, priority, currentUserId): IssueResult
    +addComment(issueId, content, currentUserId): CommentResult
  }

  class AssignmentService <<service>> {
    +startAssignment(issueId, currentUserId): AssignmentOptions
    +assignIssue(issueId, assigneeId, verifierId, currentUserId): AssignmentResult
    +reassignIssue(issueId, assigneeId, currentUserId): AssignmentResult
    +changeVerifier(issueId, verifierId, currentUserId): AssignmentResult
  }

  class IssueStateService <<service>> {
    +changeStatus(issueId, targetStatus, comment, currentUserId): IssueStateResult
  }

  class DeletedIssueService <<service>> {
    +viewDeletedIssues(projectId, actor): List<Issue>
    +deleteIssue(issueId, comment, actor): Issue
    +restoreIssue(issueId, comment, actor): Issue
    +purgeOverflow(projectId, actor): int
  }

  class AccountService <<service>>

  class ProjectService <<service>> {
    +viewProjects(currentUserId): List<Project>
    +viewProject(projectId, currentUserId): Project
    +viewProjectParticipants(projectId, currentUserId): List<ProjectMember>
    +viewProjectDetail(projectId, currentUserId): ProjectDetail
    +createProject(name, description, currentUserId): Project
    +deleteProject(projectId, currentUserId): void
    +addProjectParticipant(projectId, loginId, currentUserId): void
    +removeProjectParticipant(projectId, loginId, currentUserId): void
  }

  class ProjectDetail <<read model>> {
    +project(): Project
    +participants(): List<ProjectMember>
    +issues(): List<Issue>
  }

  class AssignmentRecommendationService <<service>> {
    +recommendAssignmentCandidates(issue): AssignmentOptions
    +findDevAssigneeCandidates(issue): List<User>
    +findTesterVerifierCandidates(issue): List<User>
  }

  class StatisticsService <<service>> {
    +viewStatistics(projectId, dailyFromInclusive, dailyToInclusive, monthlyFromInclusive, monthlyToInclusive, actor): StatisticsReport
  }

  class Clock <<service>> {
    +now(): DateTime
  }
}

package "Repository Interfaces\n(interfaces / contracts)" #F8FAFC {
  interface ProjectRepository <<interface>> {
    +findById(projectId): Project
    +findByName(name): Project
    +findAll(): List<Project>
    +findParticipants(projectId): List<ProjectMember>
    +save(project): void
    +deleteById(projectId): void
    +addParticipant(projectId, loginId): void
    +removeParticipant(projectId, loginId): void
  }

  interface IssueRepository <<interface>> {
    +findById(issueId): Issue
    +findByProject(projectId): List<Issue>
    +findDeletedByProject(projectId): List<Issue>
    +findByCriteria(filters): List<Issue>
    +save(issue): void
    +deleteDependency(dependency): void
    +purge(issue): void
  }

  interface UserRepository <<interface>> {
    +findById(loginId): User
    +findActiveByRole(projectId, role): List<User>
    +save(user): void
  }
}

package "Technical Services\n(concrete adapters and security support)" #F3E5F5 {
  class JdbcProjectRepository <<repository>> {
    -connectionProvider: DatabaseConnectionProvider
    +deleteById(projectId): void
  }

  class JdbcIssueRepository <<repository>> {
    -connectionProvider: DatabaseConnectionProvider
  }

  class JdbcUserRepository <<repository>> {
    -connectionProvider: DatabaseConnectionProvider
  }

  class DatabaseConnectionProvider <<service>> {
    +getConnection(): Connection
  }

  class PasswordHasher <<service>> {
    +hash(password): String
    +matches(password, passwordHash): boolean
  }

  class SessionStore <<service>> {
    +startSession(user): void
    +currentUser(): User
    +clear(): void
  }
}

package "Domain Layer\n(concrete entities, value objects, enums)" #F1F8E9 {
  class Project <<entity>> {
    -projectId: ProjectId
    -name: Text
    -description: Text
    -createdDate: DateTime
    +rename(newName, updatedAt): void
    +changeDescription(newDescription, updatedAt): void
  }

  class Issue <<aggregate root>> {
    -issueId: IssueId
    -title: Text
    -description: Text
    -reportedDate: DateTime
    -priority: Priority
    -status: IssueStatus
    -reporter: User
    -assignee: User
    -verifier: User
    -fixer: User
    -resolver: User
    +create(state): Issue
    +fromPersistence(state): Issue
    +updateTitleAndDescription(title, description, changedBy, now): void
    +addComment(content, writer, now): Comment
    +addHistory(history): void
    +verifyPriorityChange(newPriority): ValidationResult
    +changePriority(newPriority, changedBy, now): void
    +getAssignmentContext(): AssignmentContext
    +assignFromNew(assignee, verifier, changedBy, now): void
    +assignReopened(assignee, verifier, changedBy, now): void
    +reassignAssignee(assignee, changedBy, now): void
    +changeVerifier(verifier, changedBy, now): void
    +markFixed(dev, comment, now): void
    +checkResolvePreconditions(tester, comment): ValidationResult
    +resolve(tester, comment, now): void
    +verifyRejectFixPreconditions(tester, comment): ValidationResult
    +rejectFix(tester, comment, now): void
    +verifyClosePreconditions(pl, comment): ValidationResult
    +close(pl, comment, now): void
    +verifyReopenPreconditions(pl, comment): ValidationResult
    +reopen(pl, comment, now): void
    +clearAssignee(): void
    +clearVerifier(): void
    +softDelete(pl, now): void
    +restore(pl, now): void
    +findDeleteStatusHistory(): IssueHistory
    +validateDependencyCandidate(blockingIssue): ValidationResult
    +addDependency(blockingIssue, changedBy, now): IssueDependency
    +removeDependency(dependency, changedBy, now): void
  }

  class User <<entity>> {
    -loginId: Text
    -name: Text
    -passwordHash: Text
    -role: Role
    -isActive: boolean
    +hasRole(role): boolean
    +isActive(): boolean
  }

  class Comment <<entity>> {
    -commentId: CommentId
    -content: Text
    -createdDate: DateTime
    -writer: User
  }

  class IssueHistory <<entity>> {
    -historyId: HistoryId
    -action: ActionType
    -previousValue: Text
    -newValue: Text
    -changedBy: User
    -changedDate: DateTime
    -message: Text
  }

  class IssueDependency <<entity>> {
    -dependencyId: DependencyId
    -blockingIssue: Issue
    -blockedIssue: Issue
    -discoveredDate: DateTime
    +removeBlockingAndBlockedAssociations(): void
  }

  enum Role {
    ADMIN
    PL
    DEV
    TESTER
  }

  enum IssueStatus {
    NEW
    ASSIGNED
    FIXED
    RESOLVED
    CLOSED
    REOPENED
    DELETED
  }

  enum Priority {
    BLOCKER
    CRITICAL
    MAJOR
    MINOR
    TRIVIAL
  }

  enum ActionType {
    CREATED
    TITLE_DESCRIPTION_UPDATED
    PRIORITY_CHANGED
    STATUS_CHANGED
    ASSIGNMENT_CHANGED
    DEPENDENCY_CHANGED
    COMMENTED
  }

  class AssignmentOptions <<value object>>
  class AssignmentContext <<value object>>
  class ValidationResult <<value object>>
  class StatisticsReport <<value object>>
}

