  class AccountService <<service>> {
    +createAccount(loginId, name, password, role, actor): UserResult
    +renameAccount(loginId, name, actor): UserResult
    +changeAccountRole(loginId, role, actor): UserResult
    +activateAccount(loginId, actor): UserResult
    +deactivateAccount(loginId, actor): UserResult
  }

  class ProjectService <<service>> {
    +viewProjectNonAdminDetail(projectId, currentLoginId): ProjectResult
    +viewProjectAdminDetail(projectId, currentLoginId): ProjectAdminDetail
    +viewProjectParticipants(projectId, currentLoginId): List<ProjectMemberResult>
    +createProject(name, description, currentLoginId): ProjectResult
    +renameProject(projectId, name, currentLoginId): ProjectResult
    +changeProjectDescription(projectId, description, currentLoginId): ProjectResult
    +deleteProject(projectId, currentLoginId): void
    +addProjectParticipant(projectId, loginId, currentLoginId): void
    +removeProjectParticipant(projectId, loginId, currentLoginId): void
  }

  class IssueService <<service>> {
    +registerIssue(projectId, title, description, priority, currentLoginId): IssueResult
    +viewIssueDetail(issueId, currentLoginId): IssueDetailResult
    +searchIssues(projectId, keyword, status, priority, reporterId, assigneeId, verifierId, reportedFrom, reportedTo, currentLoginId): List<IssueSummary>
    +viewRelatedProjectIssues(projectId, currentLoginId): List<IssueSummary>
    +updateIssue(issueId, title, description, currentLoginId): IssueResult
    +changePriority(issueId, priority, currentLoginId): IssueResult
    +addComment(issueId, content, currentLoginId): CommentResult
    +viewComments(issueId, currentLoginId): List<CommentResult>
    +updateComment(issueId, commentId, content, currentLoginId): CommentResult
    +deleteComment(issueId, commentId, currentLoginId): void
    +addDependency(blockingIssueId, blockedIssueId, currentLoginId): DependencyResult
    +viewProjectDependencies(projectId, currentLoginId): List<DependencyResult>
    +removeDependency(blockingIssueId, blockedIssueId, currentLoginId): void
  }

  class AssignmentService <<service>> {
    +startAssignment(issueId, loginId): AssignmentOptionsResult
    +assignIssue(issueId, assigneeId, verifierId, loginId): AssignmentResult
    +reassignIssue(issueId, assigneeId, loginId): AssignmentResult
    +changeVerifier(issueId, verifierId, loginId): AssignmentResult
  }

  class AssignmentRecommendationService <<service>> {
    +recommendAssignmentCandidates(issue): AssignmentOptionsResult
  }

  class IssueStateService <<service>> {
    +changeStatus(issueId, targetStatus, comment, currentLoginId): IssueStateResult
  }

  class DeletedIssueService <<service>> {
    +viewDeletedIssues(projectId, actor): List<IssueSummary>
    +deleteIssue(issueId, comment, actor): IssueSummary
    +restoreIssue(issueId, comment, actor): IssueSummary
    +purgeOverflow(projectId, actor): int
    +purgeDeletedIssue(issueId, actor): void
  }

  class StatisticsService <<service>> {
    +viewStatistics(projectId, dailyFrom, dailyTo, monthlyFrom, monthlyTo, actor): StatisticsReportResult
  }

  class LoginCheckService <<service>>
  class RepositoryDemoSummaryService <<service>>

  class PermissionPolicy <<policy>> {
    +assertCanRegisterIssue(user, project): void
    +assertCanViewIssue(user): void
    +assertCanAssignIssue(user, issue): void
    +assertCanAddComment(user, issue): void
    +assertCanUpdateIssue(user, issue): void
    +assertCanChangeStatus(user, issue, targetStatus): void
    +assertCanManageDeletedIssue(user, issue): void
    +assertCanManageDeletedIssue(user, projectId): void
    +assertCanManageDependency(user, issue): void
    +assertCanChangePriority(user, issue): void
    +assertCanUpdateComment(user, comment): void
    +assertCanDeleteComment(user, comment): void
    +assertCanManageAccount(user): void
    +assertCanManageProject(user): void
    +canViewAllProjects(user): boolean
    +canViewAllUsers(user): boolean
    +canViewAllProjectIssues(user): boolean
    +assertCanViewStatistics(user): void
  }

  interface Clock <<port>> {
    +now(): LocalDateTime
  }

  interface CurrentUserSession <<port>> {
    +start(user): void
    +currentUser(): Optional<User>
    +clear(): void
  }

  interface CommentIdProvider <<port>> {
    +nextCommentId(): String
  }

  interface PasswordHashing <<port>> {
    +hash(password): String
    +matches(password, passwordHash): boolean
  }

  class IssueResult <<result>>
  class IssueSummary <<result>>
  class IssueDetailResult <<result>>
  class CommentResult <<result>>
  class HistoryResult <<result>>
  class DependencyResult <<result>>
  class AssignmentResult <<result>>
  class AssignmentOptionsResult <<result>>
  class AssignmentCandidateResult <<result>>
  class IssueStateResult <<result>>
  class ProjectResult <<result>>
  class ProjectAdminDetail <<result>>
  class ProjectMemberResult <<result>>
  class DashboardProjectSummary <<result>>
  class UserResult <<result>>
  class StatisticsReportResult <<result>>
