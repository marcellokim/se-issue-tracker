@startuml sd-12-delete-issue-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 12 - Delete Issue
hide footbox

actor "PL" as PL
participant ":IssueTrackingSystem" as DIC
participant "targetIssue:Issue" as Issue
participant "relatedDependency:IssueDependency" as Dependency

PL -> DIC : deleteIssue(issueId, comment)

alt 상태 또는 권한 조건이 맞지 않음
  DIC --> PL : deleteRejected(reason)
else 삭제 사유가 비어 있음
  DIC --> PL : deleteRejected(commentRequired)
else soft delete 대상 조건을 만족함
  DIC -> Issue : markDeleted(currentPL, comment, now)
  activate Issue

  loop targetIssue와 관련된 각 dependency
    Issue -> Dependency : removeFromIssueGraph()
    destroy Dependency
  end

  create "deleteHistory:IssueHistory" as History
  Issue --> History : new(STATUS_CHANGED,\nNEW/CLOSED -> DELETED)
  Issue -> Issue : status=DELETED;\naddHistory(deleteHistory)
  Issue --> DIC : deleted(status=DELETED)
  deactivate Issue

  opt deleted issue 보관 한도를 초과함
    DIC -> DIC : purgeOldestDeletedIssue()
  end

  DIC --> PL : issueDeleted(issueId, status=DELETED)
end

@enduml
