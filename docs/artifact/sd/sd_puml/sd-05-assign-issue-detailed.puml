@startuml sd-05-assign-issue-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 05 - Assign / Update Issue Assignment
hide footbox

actor "PL" as PL
participant ":IssueTrackingSystem" as AC
participant "targetIssue:Issue" as Issue
participant "projectMembers:User[*]" as Members
participant "assignmentHistory:IssueHistory[*]" as PastHistory

PL -> AC : startAssignment(issueId)

alt PL이 이 이슈를 배정할 수 없음
  AC --> PL : assignmentRejected(reason)
else 배정 화면을 시작할 수 있음
  AC -> Issue : readAssignmentState()
  Issue --> AC : status, currentAssignee,\ncurrentVerifier, fixer, resolver

  AC -> Issue : determineNeededRoles()
  Issue --> AC : needed assignee/verifier role
  AC -> Members : selectActiveMembersByRole(neededRoles)
  Members --> AC : candidate users
  AC -> PastHistory : summarizePastAssignments(candidate users)
  PastHistory --> AC : ranking hints
  AC -> AC : order candidates by role,\nstatus, and past work

  AC --> PL : assignmentOptions(...)
end

alt 이슈 상태가 NEW임
  PL -> AC : assignIssue(issueId, assigneeId, verifierId)
  AC -> Issue : assignFromNew(assignee, verifier, currentPL, now)
  activate Issue
  Issue -> Issue : set assignee/verifier;\nstatus = ASSIGNED
  create "assignmentHistory:IssueHistory" as NewAH
  Issue --> NewAH : new(ASSIGNMENT_CHANGED)
  create "statusHistory:IssueHistory" as NewSH
  Issue --> NewSH : new(STATUS_CHANGED, NEW -> ASSIGNED)
  Issue -> Issue : addHistory(assignmentHistory)
  Issue -> Issue : addHistory(statusHistory)
  Issue --> AC : assigned(status=ASSIGNED)
  deactivate Issue
  AC --> PL : issueAssigned(issueId, status=ASSIGNED)

else 이슈 상태가 REOPENED임
  PL -> AC : assignIssue(issueId, assigneeId, verifierId)
  AC -> Issue : assignReopened(assignee, verifier, currentPL, now)
  activate Issue
  Issue -> Issue : replace assignee/verifier;\npreserve fixer/resolver;\nstatus = ASSIGNED
  create "assignmentHistory:IssueHistory" as ReopenedAH
  Issue --> ReopenedAH : new(ASSIGNMENT_CHANGED)
  create "statusHistory:IssueHistory" as ReopenedSH
  Issue --> ReopenedSH : new(STATUS_CHANGED, REOPENED -> ASSIGNED)
  Issue -> Issue : addHistory(assignmentHistory)
  Issue -> Issue : addHistory(statusHistory)
  Issue --> AC : assigned(status=ASSIGNED)
  deactivate Issue
  AC --> PL : issueAssigned(issueId, status=ASSIGNED)

else 이슈 상태가 ASSIGNED임
  PL -> AC : reassignIssue(issueId, assigneeId)
  AC -> Issue : reassignAssignee(assignee, currentPL, now)
  activate Issue
  Issue -> Issue : replace assignee;\nkeep status/verifier/fixer/resolver
  create "assignmentHistory:IssueHistory" as ReassignAH
  Issue --> ReassignAH : new(ASSIGNMENT_CHANGED)
  Issue -> Issue : addHistory(assignmentHistory)
  Issue --> AC : reassigned(status=ASSIGNED)
  deactivate Issue
  AC --> PL : issueReassigned(issueId, status=ASSIGNED)

else 이슈 상태가 FIXED임
  PL -> AC : changeVerifier(issueId, verifierId)
  AC -> Issue : changeVerifier(verifier, currentPL, now)
  activate Issue
  Issue -> Issue : replace verifier;\nkeep status/assignee/fixer/resolver
  create "assignmentHistory:IssueHistory" as VerifierAH
  Issue --> VerifierAH : new(ASSIGNMENT_CHANGED)
  Issue -> Issue : addHistory(assignmentHistory)
  Issue --> AC : verifierChanged(status=FIXED)
  deactivate Issue
  AC --> PL : verifierChanged(issueId, status=FIXED)
end

opt PL이 배정 관련 댓글을 추가함
  PL -> AC : addComment(issueId, content)
  alt 댓글 내용이 비어 있음
    AC --> PL : commentRejected(reason)
  else 댓글이 정상 입력됨
    AC -> Issue : addComment(content, currentPL, now)
    activate Issue
    create "assignmentComment:Comment" as Comment
    Issue --> Comment : new(content, writer=currentPL, createdAt=now)
    create "commentHistory:IssueHistory" as CommentHistory
    Issue --> CommentHistory : new(COMMENTED, message="comment added")
    Issue -> Issue : addComment(assignmentComment)
    Issue -> Issue : addHistory(commentHistory)
    Issue --> AC : commentAdded(commentId)
    deactivate Issue
    AC --> PL : commentAdded(commentId)
  end
end

@enduml
