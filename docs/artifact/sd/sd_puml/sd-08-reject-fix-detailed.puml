@startuml sd-08-reject-fix-detailed
!include ../_shared/its-uml-style.puml

title Detailed SD 08 - Reject Fix
hide footbox

actor "Tester" as Tester
participant ":IssueTrackingSystem" as ISC
participant "targetIssue:Issue" as Issue

Tester -> ISC : changeStatus(issueId, ASSIGNED, comment)

alt 상태 또는 권한 조건이 맞지 않음
  ISC --> Tester : statusChangeRejected(reason)
else 상태 변경 사유가 비어 있음
  ISC --> Tester : statusChangeRejected(commentRequired)
else FIXED -> ASSIGNED 전이가 가능함
  ISC -> Issue : rejectFix(currentTester, comment, now)
  activate Issue
  create "rejectComment:Comment" as Comment
  Issue --> Comment : new(content=comment,\nwriter=currentTester,\npurpose=STATUS_CHANGE)
  create "commentHistory:IssueHistory" as CommentHistory
  Issue --> CommentHistory : new(COMMENTED, message=comment)
  create "statusHistory:IssueHistory" as StatusHistory
  Issue --> StatusHistory : new(STATUS_CHANGED, FIXED -> ASSIGNED)
  Issue -> Issue : keep assignee/verifier/fixer;\nstatus=ASSIGNED
  Issue --> ISC : updated(status=ASSIGNED)
  deactivate Issue
  ISC --> Tester : updatedIssue(issueId, status=ASSIGNED)
end

@enduml
